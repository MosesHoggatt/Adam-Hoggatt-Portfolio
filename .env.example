# AWS Amplify Configuration
# These values are generated automatically by Amplify CLI in aws-exports.js
# This file is for reference only - you don't need to set these manually

# VITE_AWS_REGION=us-east-1
# VITE_USER_POOL_ID=your-user-pool-id
# VITE_USER_POOL_CLIENT_ID=your-client-id
# VITE_IDENTITY_POOL_ID=your-identity-pool-id
# VITE_S3_BUCKET=your-bucket-name

# Note: Vite requires environment variables to be prefixed with VITE_
# However, AWS Amplify uses aws-exports.js instead of .env for configuration
# So you typically don't need a .env file for Amplify projects
